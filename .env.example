# ──────────────────────────────────────────────────────────────
#  CIPHER — environment variables
#  Copy this file to ".env.local" and fill in the real values.
#  .env.local is gitignored and never leaves your machine / host.
# ──────────────────────────────────────────────────────────────

# --- Intelligence layer (Claude) ---
# Get a key at https://console.anthropic.com  → API Keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx

# Which model the reasoning layer uses. Sonnet is the balanced default.
# Check https://docs.claude.com for the current model strings.
CIPHER_MODEL=claude-sonnet-4-6

# --- Data & Memory layer (Supabase) ---
# Project URL: from the "Connect" dialog (or Settings -> Data API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
# A server-side secret key. Settings -> API Keys: either a new "Secret key"
# (sb_secret_...) or the legacy service_role key. Bypasses RLS — server only,
# never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=sb_secret_or_legacy_service_role_key

# --- Single-user setup ---
# Cipher is built for one person. Generate any UUID once and keep it fixed.
# (e.g. run: node -e "console.log(crypto.randomUUID())" )
CIPHER_USER_ID=00000000-0000-0000-0000-000000000001

# --- Automation layer (cron) ---
# A secret string of your choosing. Cron requests must send it so random
# visitors can't trigger your background jobs.
CRON_SECRET=change-me-to-a-long-random-string
